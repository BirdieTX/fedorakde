[Desktop Entry]
Categories=Utility;
Comment=
Exec=/usr/bin/flatpak run --branch=stable --arch=x86_64 --command=start-proton-pass --file-forwarding me.proton.Pass @@u %U @@
GenericName=Password Manager
Icon=me.proton.Pass
Name=Proton Pass
NoDisplay=false
Path=
PrefersNonDefaultGPU=false
StartupNotify=true
Terminal=false
TerminalOptions=
Type=Application
X-Desktop-File-Install-Version=0.28
X-Flatpak=me.proton.Pass
X-KDE-SubstituteUID=false
X-KDE-Username=
